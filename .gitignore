# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
# fail2ban's own convention requires this exact filename (jail.local
# overrides jail.conf) — versioned deliberately, not a stray local
# override file the *.local rule above is meant to catch.
!ops/host/fail2ban/jail.local
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
